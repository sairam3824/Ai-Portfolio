{
  "name": "ai-portfolio-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "workspaces": [
    "Version1",
    "Version2",
    "Version3"
  ],
  "scripts": {
    "check:writing": "node --import tsx scripts/check-writing-invariants.ts",
    "check:metrics": "node --import tsx scripts/check-public-metrics.ts",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "lint": "npm run lint --workspaces --if-present",
    "check:bundle": "node --import tsx scripts/check-version3-bundle-budget.ts",
    "verify": "npm run check:writing && npm run check:metrics && npm run test && npm run lint && npm run build:ci && npm run check:bundle",
    "build": "npm run build:deploy",
    "build:ci": "npm run build --workspace Version1 && npm run build --workspace Version2 && npm run build --workspace Version3",
    "build:deploy": "npm run check:writing && npm run check:metrics && npm run build --workspace Version3 && npm run check:bundle && npm run build --workspace Version1 && node --import tsx scripts/copy-version1-dist.ts",
    "branch-protect:apply": "node --import tsx scripts/apply-branch-protection.ts",
    "content:snapshot": "node --import tsx scripts/export-shared-data-snapshot.ts",
    "clean:generated": "node --import tsx scripts/clean-generated-files.ts",
    "newsletter:send": "node --import tsx scripts/send-latest-blog-newsletter.ts",
    "newsletter:deploy": "npm run newsletter:send"
  },
  "devDependencies": {
    "lucide-react": "^1.7.0",
    "tsx": "^4.20.6"
  },
  "dependencies": {
    "openai": "^6.33.0"
  }
}
